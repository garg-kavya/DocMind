# Normalize line endings: store as LF, checkout as native
* text=auto

# Force LF for files that must be LF in Docker/Linux
*.py text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Binary files — no line ending conversion
*.pdf binary
*.png binary
*.jpg binary
*.ico binary
